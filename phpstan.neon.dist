includes:
  - vendor/larastan/larastan/extension.neon
  # Baseline contains only Larastan framework false positives that cannot be
  # resolved without sacrificing runtime-correct code (belongsTo nullability
  # and belongsToMany pivot typing).
  - phpstan-baseline.neon

parameters:
  paths:
    - app
  level: 6
  checkMissingTypehints: true
  reportUnmatchedIgnoredErrors: true
  tmpDir: var/phpstan
  excludePaths:
    - vendor/*
    - storage/*
    - bootstrap/cache/*
