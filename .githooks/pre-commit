#!/bin/sh
set -e

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

STAGED_PHP_FILES="$(git diff --cached --name-only --diff-filter=ACM | grep '\.php$' || true)"

if [ -z "$STAGED_PHP_FILES" ]; then
    exit 0
fi

echo "pre-commit: running Pint and PHPStan (same checks as CI)..."

composer quality
