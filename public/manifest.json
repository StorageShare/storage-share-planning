        {
            "src": "/images/icon-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any maskable"
        }
    ],
    "shortcuts": [
        {
            "name": "Vandaag Planning",
            "short_name": "Vandaag",
            "description": "Bekijk de planning voor vandaag",
            "url": "/my-planning",
            "icons": [
                {
                    "src": "/images/shortcut-today.png",
                    "sizes": "96x96"
                }
            ]
        },
        {
            "name": "Dashboard",
            "short_name": "Dashboard",
            "description": "Ga naar het hoofddashboard",
            "url": "/dashboard",
            "icons": [
                {
                    "src": "/images/shortcut-dashboard.png",
                    "sizes": "96x96"
                }
            ]
        }
    ],
    "screenshots": [
        {
            "src": "/images/screenshot-planning.png",
            "sizes": "1280x720",
            "type": "image/png",
            "platform": "wide",
            "label": "Planning overzicht met taken en locaties"
        },
        {
            "src": "/images/screenshot-mobile.png",
            "sizes": "750x1334",
            "type": "image/png",
            "platform": "narrow",
            "label": "Mobiele weergave van de planning"
        }
    ],
    "related_applications": [],
    "prefer_related_applications": false,
    "features": [
        "offline",
        "installable",
        "background-sync"
    ],
    "edge_side_panel": {
        "preferred_width": 400
    },
    "launch_handler": {
        "client_mode": "navigate-existing"
    },
    "offline_enabled": true,
    "cache_enabled": true,
    "file_handlers": [
        {
            "action": "/my-planning",
            "accept": {
                "application/json": [".json"]
            }
        }
    ],
    "protocol_handlers": [
        {
            "protocol": "web+planning",
            "url": "/my-planning?planning=%s"
        }
    ]
} 